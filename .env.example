# ============================================================
# 🛡️ VISUAL AI — SECURE ENVIRONMENT VARIABLES
# ============================================================
# Copy this to .env and fill with your real values.

# === AZURE OPENAI (REQUIRED) ===
AZURE_OPENAI_ENDPOINT=https://cronus.openai.azure.com/
AZURE_OPENAI_KEY=sua-chave-azure-openai
AZURE_OPENAI_DEPLOYMENT=4.1-nano
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# === SERVER ===
SERVER_PORT=3001
NODE_ENV=development

# === SECURITY ===
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# === FRONTEND ===
# URL of the backend API (injected into frontend build)
VITE_API_URL=http://localhost:3001
